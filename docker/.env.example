# ============================================================
# GitHub
# ============================================================
GITHUB_USER=your-github-username

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_HOST_PORT=5432
POSTGRES_PASSWORD=change-me-postgres-password

# ============================================================
# Cloudflare Tunnel
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# ============================================================
# Homepage Dashboard
# ============================================================
HOMEPAGE_ALLOWED_HOSTS=home.yourdomain.com

# ============================================================
# Musicas Igreja
# ============================================================
MUSICAS_DB_USER=musicas_user
MUSICAS_DB_PASSWORD=change-me-musicas

# ============================================================
# Gerenciamento Pastoral
# ============================================================
PASTORAL_DB_USER=pastoral_user
PASTORAL_DB_PASSWORD=change-me-pastoral

# ============================================================
# Gerenciamento Financeiro
# ============================================================
FINANCEIRO_DB_USER=financeiro_user
FINANCEIRO_DB_PASSWORD=change-me-financeiro
FINANCEIRO_COOKIE_DOMAIN=your-domain.com

# ============================================================
# Gestao Aulas de Musica
# ============================================================
AULAS_DB_USER=aulas_user
AULAS_DB_PASSWORD=change-me-aulas
AULAS_COOKIE_DOMAIN=your-domain.com
